# Auth access/refresh token settings
# Copy these keys into server/.env and adjust per environment.

ACCESS_TOKEN_SECRET=replace-with-long-random-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# Refresh cookie settings (mainly used by Web; iOS can read refresh token from response body)
AUTH_REFRESH_COOKIE_NAME=raver_refresh_token
AUTH_REFRESH_COOKIE_PATH=/v1/auth
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false

# SMS provider settings
# Supported values: mock | aliyun
AUTH_SMS_PROVIDER=mock
AUTH_SMS_CODE_LENGTH=6
AUTH_SMS_CODE_TTL_MS=300000
AUTH_SMS_SEND_COOLDOWN_MS=60000
AUTH_SMS_PHONE_HOURLY_LIMIT=5
AUTH_SMS_IP_HOURLY_LIMIT=30
AUTH_SMS_VERIFY_FAILURE_LIMIT=10
AUTH_SMS_VERIFY_BLOCK_MS=900000
# Dev fallback: in mock mode return debugCode in /v1/auth/sms/send response.
# Always keep false in production.
AUTH_SMS_DEBUG_RETURN_CODE=false
# Optional phone allowlist (comma-separated, E.164). Empty means all phones in non-prod.
AUTH_SMS_DEBUG_PHONE_ALLOWLIST=
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=3600000
AUTH_REGISTER_RATE_LIMIT_MAX_ATTEMPTS=10

# Aliyun SMS settings (required when AUTH_SMS_PROVIDER=aliyun)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE_LOGIN=
ALIYUN_SMS_REGION_ID=cn-hangzhou
