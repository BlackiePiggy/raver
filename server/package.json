{
  "name": "raver-server",
  "version": "1.0.0",
  "description": "Raver API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS='--use-env-proxy' nodemon src/index.ts",
    "build": "tsc",
    "start": "NODE_OPTIONS='--use-env-proxy' node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:backfill:user-profiles": "ts-node prisma/backfill-user-profiles.ts",
    "prisma:seed:live-feed-posts": "ts-node prisma/seed-live-feed-posts.ts",
    "labels:import": "ts-node prisma/import-labelsbase.ts",
    "djs:import:edmdd": "ts-node prisma/import-edmdancedirectory-djs.ts",
    "djs:avatars:oss": "ts-node prisma/upload-dj-avatars-to-oss.ts",
    "djs:avatars:spotify-placeholder-fix": "ts-node prisma/backfill-dj-placeholder-avatars-via-spotify.ts",
    "djs:backfill:soundcloud-links": "NODE_OPTIONS='--use-env-proxy' ts-node prisma/backfill-dj-soundcloud-links.ts",
    "djs:backfill:soundcloud-links:20s": "SOUNDCLOUD_MIN_REQUEST_INTERVAL_MS=20000 DJ_SC_BACKFILL_CONCURRENCY=1 NODE_OPTIONS='--use-env-proxy' ts-node prisma/backfill-dj-soundcloud-links.ts",
    "djs:contributors:backfill-uploadtester": "ts-node prisma/backfill-dj-contributors-uploadtester.ts",
    "events:import:archive-bilingual": "NODE_OPTIONS='--use-env-proxy' ts-node prisma/import-events-archive-bilingual.ts",
    "events:lineup:autobind-djs": "ts-node prisma/backfill-event-lineup-autobind-djs.ts",
    "wiki:festivals:seed-uploadtester": "ts-node prisma/seed-wiki-festivals.ts",
    "wiki:festivals:media:backfill-oss": "ts-node prisma/backfill-wiki-festival-media-from-oss.ts",
    "country:backfill:en-full": "ts-node prisma/backfill-country-en-full.ts",
    "brands:import:downloads": "ts-node prisma/import-wiki-festivals-from-downloads.ts",
    "brands:import:complete-json": "ts-node prisma/import-wiki-festivals-complete-json.ts",
    "notification:event-countdown:run": "ts-node src/scripts/notification-event-countdown-run.ts",
    "notification:event-daily-digest:run": "ts-node src/scripts/notification-event-daily-digest-run.ts",
    "notification:route-dj-reminder:run": "ts-node src/scripts/notification-route-dj-reminder-run.ts",
    "notification:outbox:run": "ts-node src/scripts/notification-outbox-run.ts",
    "notification:outbox:gray-verify": "ts-node src/scripts/notification-outbox-gray-verify.ts",
    "notification:followed-dj-update:run": "ts-node src/scripts/notification-followed-dj-update-run.ts",
    "notification:followed-brand-update:run": "ts-node src/scripts/notification-followed-brand-update-run.ts",
    "notification:compat:regression": "ts-node src/scripts/notification-compat-regression.ts",
    "notification:normalize-device-platforms": "ts-node src/scripts/notification-normalize-device-platforms.ts",
    "auth:smoke": "ts-node src/scripts/auth-smoke.ts",
    "auth:integration": "ts-node src/scripts/auth-integration.ts",
    "tencent-im:sync:all-users": "NODE_OPTIONS='--use-env-proxy' ts-node src/scripts/tencent-im-sync-all-users.ts",
    "tencent-im:export:user-mapping": "ts-node src/scripts/tencent-im-export-user-mapping.ts",
    "tencent-im:delete:openim-users": "NODE_OPTIONS='--use-env-proxy' ts-node src/scripts/tencent-im-delete-openim-users.ts"
  },
  "keywords": [
    "raver",
    "api",
    "music"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "ali-oss": "^6.23.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "tls-sig-api-v2": "^1.0.2"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.10",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
