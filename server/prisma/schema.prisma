  expectationMessage String?  @map("expectation_message") @db.Text
  status             String   @default("SUBMITTED")
  source             String?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  decisions     PreRegistrationDecision[]
  notifications PreRegistrationNotification[]

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@map("pre_registrations")
}

model PreRegistrationBatch {
  id           String   @id @default(uuid())
  batchName    String   @map("batch_name")
  plannedSlots Int?     @map("planned_slots")
  note         String?
  status       String   @default("OPEN")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  decisions     PreRegistrationDecision[]
  notifications PreRegistrationNotification[]

  @@index([createdAt])
  @@map("pre_registration_batches")
}

model PreRegistrationDecision {
  id             String   @id @default(uuid())
  batchId        String   @map("batch_id")
  registrationId String   @map("registration_id")
  decision       String
  decisionBy     String?  @map("decision_by")
  decisionReason String?  @map("decision_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  batch        PreRegistrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  registration PreRegistration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([batchId, registrationId])
  @@index([batchId, decision])
  @@index([registrationId, decision])
  @@map("pre_registration_decisions")
}

model PreRegistrationNotification {
  id                String   @id @default(uuid())
  registrationId    String   @map("registration_id")
  batchId           String?  @map("batch_id")
  channel           String
  templateKey       String   @map("template_key")
  sendStatus        String   @default("PENDING") @map("send_status")
  providerMessageId String?  @map("provider_message_id")
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  registration PreRegistration       @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  batch        PreRegistrationBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([batchId, channel, createdAt])
  @@index([registrationId, channel, createdAt])
  @@index([sendStatus, createdAt])
  @@map("pre_registration_notifications")
}

