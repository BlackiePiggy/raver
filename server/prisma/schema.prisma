  userId             String    @map("user_id")
  content            String    @db.Text
  titleI18n          Json?     @map("title_i18n")
  summaryI18n        Json?     @map("summary_i18n")
  bodyI18n           Json?     @map("body_i18n")
  images             String[]  @default([])
  location           String?
  type               String    @default("general") // general, event, set, squad
  visibility         String    @default("public") // public, friends, squad
  squadId            String?   @map("squad_id")
  eventId            String?   @map("event_id")
  setId              String?   @map("set_id")
  boundDjIds         String[]  @default([]) @map("bound_dj_ids")
  boundBrandIds      String[]  @default([]) @map("bound_brand_ids")
  boundEventIds      String[]  @default([]) @map("bound_event_ids")
  displayPublishedAt DateTime? @map("display_published_at") @db.Timestamptz(3)
  likeCount          Int       @default(0) @map("like_count")
  repostCount        Int       @default(0) @map("repost_count")
  saveCount          Int       @default(0) @map("save_count")
  shareCount         Int       @default(0) @map("share_count")
  hideCount          Int       @default(0) @map("hide_count")
  commentCount       Int       @default(0) @map("comment_count")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user       User          @relation("UserPosts", fields: [userId], references: [id], onDelete: Cascade)
  squad      Squad?        @relation(fields: [squadId], references: [id], onDelete: Cascade)
  event      Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  set        DJSet?        @relation(fields: [setId], references: [id], onDelete: SetNull)
  likes      PostLike[]
  reposts    PostRepost[]
  saves      PostSave[]
  shares     PostShare[]
  hides      PostHide[]
  feedEvents FeedEvent[]
  comments   PostComment[]

  @@index([userId])
  @@index([squadId])
  @@index([createdAt])
  @@index([type])
  @@map("posts")
}

model EventLiveComment {
  id              String   @id @default(uuid())
