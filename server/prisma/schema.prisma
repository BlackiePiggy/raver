// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  username              String    @unique
  email                 String    @unique
  phoneNumber           String?   @unique @map("phone_number")
  passwordHash          String    @map("password_hash")
  displayName           String?   @map("display_name")
  avatarUrl             String?   @map("avatar_url")
  bio                   String?
  location              String?
  favoriteDjIds         String[]  @default([]) @map("favorite_dj_ids")
  favoriteGenres        String[]  @default([]) @map("favorite_genres")
  isFollowersListPublic Boolean   @default(true) @map("is_followers_list_public")
  isFollowingListPublic Boolean   @default(true) @map("is_following_list_public")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastLoginAt           DateTime? @map("last_login_at")
  isVerified            Boolean   @default(false) @map("is_verified")
  isActive              Boolean   @default(true) @map("is_active")
  role                  String    @default("user")

  checkins            Checkin[]
  follows             Follow[]        @relation("UserFollows")
  followers           Follow[]        @relation("UserFollowers")
  uploadedSets        DJSet[]         @relation("UserUploadedSets")
  djContributions     DJContributor[]
  publishedEvents     Event[]         @relation("UserPublishedEvents")
  uploadedTracklists  Tracklist[]     @relation("UserUploadedTracklists")
  comments            Comment[]       @relation("UserComments")
  createdRatingEvents RatingEvent[]   @relation("RatingEventCreator")
  createdRatingUnits  RatingUnit[]    @relation("RatingUnitCreator")
  ratingComments      RatingComment[] @relation("RatingCommentAuthor")

  // Community & Squad
  posts                     Post[]                    @relation("UserPosts")
  postLikes                 PostLike[]
  postReposts               PostRepost[]
  postSaves                 PostSave[]
  postShares                PostShare[]
  postHides                 PostHide[]
  feedEvents                FeedEvent[]
  postComments              PostComment[]
  postCommentReplyTargets   PostComment[]             @relation("PostCommentReplyToUser")
  ledSquads                 Squad[]                   @relation("SquadLeader")
  squadMemberships          SquadMember[]
  sentInvites               SquadInvite[]             @relation("SentInvites")
  receivedInvites           SquadInvite[]             @relation("ReceivedInvites")
  squadMessages             SquadMessage[]
  directConversationsA      DirectConversation[]      @relation("DirectConversationUserA")
  directConversationsB      DirectConversation[]      @relation("DirectConversationUserB")
  directConversationReads   DirectConversationRead[]
  directMessages            DirectMessage[]
  notificationReads         NotificationRead[]
  notificationSubscriptions NotificationSubscription[]
  notificationInboxItems    NotificationInboxItem[]
  devicePushTokens          DevicePushToken[]
  notificationDeliveries    NotificationDelivery[]
  createdActivities         SquadActivity[]
  createdAlbums             SquadAlbum[]
  uploadedPhotos            SquadAlbumPhoto[]
  wikiFestivalContributions WikiFestivalContributor[]
  authRefreshTokens         AuthRefreshToken[]

  @@map("users")
}

model Event {
  id              String   @id @default(uuid())
  organizerId     String?  @map("organizer_id")
  wikiFestivalId  String?  @map("wiki_festival_id")
  archiveFestivalId String? @unique @map("archive_festival_id")
  name            String
  nameI18n        Json?    @map("name_i18n")
  slug            String   @unique
  description     String?
  descriptionI18n Json?    @map("description_i18n")
  locationI18n    Json?    @map("location_i18n")
  countryI18n     Json?    @map("country_i18n")
  cityI18n        Json?    @map("city_i18n")
  coverImageUrl   String?  @map("cover_image_url")
  lineupImageUrl  String?  @map("lineup_image_url")
  imageAssets     Json?    @map("image_assets")
  referenceLinks  String[] @default([]) @map("reference_links")
  socialLinks     Json?    @map("social_links")
  sourceProvider  String?  @map("source_provider")
  sourceEventUrl  String?  @map("source_event_url")
  eventType       String?  @map("event_type")
  organizerName   String?  @map("organizer_name")
  venueName       String?  @map("venue_name")
  venueAddress    String?  @map("venue_address")
  city            String?
  country         String?
  manualLocation  Json?    @map("manual_location")
  locationPoint   Json?    @map("location_point")
  latitude        Decimal? @db.Decimal(10, 8)
  longitude       Decimal? @db.Decimal(11, 8)
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  startTime       String   @default("00:00:00") @map("start_time")
  endTime         String   @default("23:59:59") @map("end_time")
  dayRolloverHour Int      @default(6) @map("day_rollover_hour")
  stageOrder      Json?    @map("stage_order")
  ticketUrl       String?  @map("ticket_url")
  ticketPriceMin  Decimal? @map("ticket_price_min") @db.Decimal(10, 2)
  ticketPriceMax  Decimal? @map("ticket_price_max") @db.Decimal(10, 2)
  ticketCurrency  String?  @map("ticket_currency")
  ticketNotes     String?  @map("ticket_notes")
  officialWebsite String?  @map("official_website")
  status          String   @default("upcoming")
  isVerified      Boolean  @default(false) @map("is_verified")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organizer       User?             @relation("UserPublishedEvents", fields: [organizerId], references: [id], onDelete: SetNull)
  wikiFestival    WikiFestival?     @relation(fields: [wikiFestivalId], references: [id], onDelete: SetNull)
  checkins        Checkin[]
  lineupSlots     EventLineupSlot[]
  ticketTiers     EventTicketTier[]
  posts           Post[]
  squadActivities SquadActivity[]

  @@index([organizerId])
  @@index([wikiFestivalId])
  @@map("events")
}

model EventTicketTier {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  name      String
  price     Decimal  @db.Decimal(10, 2)
  currency  String?  @map("currency")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([sortOrder])
  @@map("event_ticket_tiers")
}

model EventLineupSlot {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  djId      String?  @map("dj_id")
  djIds     String[] @default([]) @map("dj_ids")
  festivalDayIndex Int?    @map("festival_day_index")
  djName    String   @map("dj_name")
  stageName String?  @map("stage_name")
  sortOrder Int      @default(0) @map("sort_order")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dj    DJ?   @relation(fields: [djId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([djId])
  @@index([startTime])
  @@map("event_lineup_slots")
}

model DJ {
  id              String   @id @default(uuid())
  name            String
  nameI18n        Json?    @map("name_i18n")
  aliases         String[] @default([])
  genres          String[] @default([])
  slug            String   @unique
  bio             String?
  bioI18n         Json?    @map("bio_i18n")
  avatarUrl       String?  @map("avatar_url")
  avatarSourceUrl String?  @map("avatar_source_url")
  bannerUrl       String?  @map("banner_url")
  country         String?
  countryI18n     Json?    @map("country_i18n")
  spotifyId       String?  @map("spotify_id")
  spotifyFollowers Int?    @map("spotify_followers")
  appleMusicId    String?  @map("apple_music_id")
  soundcloudUrl   String?  @map("soundcloud_url")
  soundcloudId    String?  @map("soundcloud_id")
  website         String?  @map("website")
  trackCount      Int?     @map("track_count")
  playlistCount   Int?     @map("playlist_count")
  soundCloudFollowers Int? @map("soundcloud_followers")
  soundCloudFavorites Int? @map("soundcloud_favorites")
  instagramUrl    String?  @map("instagram_url")
  facebookUrl     String?  @map("facebook_url")
  twitterUrl      String?  @map("twitter_url")
  youtubeUrl      String?  @map("youtube_url")
  isVerified      Boolean  @default(false) @map("is_verified")
  followerCount   Int      @default(0) @map("follower_count")

  // EDM Dance Directory source fields
  sourceId                 String?   @map("source_id")
  sourceAddedAt            DateTime? @map("source_added_at")
  sourceUpdatedAt          DateTime? @map("source_updated_at")
  sourceArtistType         String?   @map("source_artist_type")
  sourceDataSource         String?   @map("source_data_source")
  sourceSameAs             String[]  @default([]) @map("source_same_as")
  sourceGenres             String[]  @default([]) @map("source_genres")
  sourceLabels             String[]  @default([]) @map("source_labels")
  sourceWebsite            String?   @map("source_website")
  sourceWikipedia          String?   @map("source_wikipedia")
  sourceTiktok             String?   @map("source_tiktok")
  sourceBookingAgency      String?   @map("source_booking_agency")
  sourceBookingAgent       String?   @map("source_booking_agent")
  sourceBookingUrl         String?   @map("source_booking_url")
  sourceRealName           String?   @map("source_real_name")
  sourceBirthDate          String?   @map("source_birth_date")
  sourceNationality        String?   @map("source_nationality")
  sourceYearsActive        String?   @map("source_years_active")
  sourceDiscographyCount   Int?      @map("source_discography_count")
  sourceUpcomingShows      Int       @default(0) @map("source_upcoming_shows")
  sourceLineupEventCount   Int       @default(0) @map("source_lineup_event_count")
  sourceLineupCityCount    Int       @default(0) @map("source_lineup_city_count")
  sourcePromotionScore     Int       @default(0) @map("source_promotion_score")
  sourceTotalVotes         Int       @default(0) @map("source_total_votes")
  sourceTrendingScore      Int       @default(0) @map("source_trending_score")
  sourceVerificationScore  Int?      @map("source_verification_score")
  sourceLastEnrichedAt     DateTime? @map("source_last_enriched_at")
  sourceLastImageAttemptAt DateTime? @map("source_last_image_attempt_at")
  sourceNextImageAttemptAt DateTime? @map("source_next_image_attempt_at")
  sourceSetlistFmMbid      String?   @map("source_setlistfm_mbid")
  sourceSetlistFmUrl       String?   @map("source_setlistfm_url")
  sourceSetlistFmFetchedAt DateTime? @map("source_setlistfm_fetched_at")

  // External data source IDs
  raId       String? @map("ra_id") // Resident Advisor ID
  discogsId  String? @map("discogs_id") // Discogs ID
  beatportId String? @map("beatport_id") // Beatport ID

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastSyncedAt DateTime? @map("last_synced_at")

  checkins      Checkin[]
  follows       Follow[]
  sets          DJSet[]
  lineupSlots   EventLineupSlot[]
  contributors  DJContributor[]
  foundedLabels Label[]           @relation("LabelFounderDJ")

  @@map("djs")
}

model DJContributor {
  id        String   @id @default(uuid())
  djId      String   @map("dj_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dj   DJ   @relation(fields: [djId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([djId, userId])
  @@index([djId])
  @@index([userId])
  @@map("dj_contributors")
}

model Genre {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  parentId    String?  @map("parent_id")
  color       String?
  iconUrl     String?  @map("icon_url")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("genres")
}

model Label {
  id               String  @id @default(uuid())
  name             String
  slug             String  @unique
  profileUrl       String  @unique @map("profile_url")
  profileSlug      String? @map("profile_slug")
  sourcePage       Int?    @map("source_page")
  sourceListingUrl String? @map("source_listing_url")
  cardId           String? @map("card_id")

  logoUrl             String? @map("logo_url")
  avatarSourceUrl     String? @map("avatar_source_url")
  backgroundSourceUrl String? @map("background_source_url")
  avatarUrl           String? @map("avatar_url")
  backgroundUrl       String? @map("background_url")

  soundcloudFollowers   Int?     @map("soundcloud_followers")
  likes                 Int?
  nation                String?
  genresPreview         String?  @map("genres_preview")
  latestReleaseListing  String?  @map("latest_release_listing")
  introductionPreview   String?  @map("introduction_preview") @db.Text
  locationPeriod        String?  @map("location_period")
  introduction          String?  @db.Text
  genres                String[] @default([])
  contacts              Json?
  linksInWeb            Json?    @map("links_in_web")
  generalContactEmail   String?  @map("general_contact_email")
  demoSubmissionUrl     String?  @map("demo_submission_url")
  demoSubmissionDisplay String?  @map("demo_submission_display")

  facebookUrl        String? @map("facebook_url")
  soundcloudUrl      String? @map("soundcloud_url")
  musicPurchaseUrl   String? @map("music_purchase_url")
  officialWebsiteUrl String? @map("official_website_url")
  founderName        String? @map("founder_name")
  foundedAt          String? @map("founded_at")
  founderDjId        String? @map("founder_dj_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  founderDj DJ? @relation("LabelFounderDJ", fields: [founderDjId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([nation])
  @@index([soundcloudFollowers])
  @@index([likes])
  @@index([founderDjId])
  @@map("labels")
}

model WikiFestival {
  id              String   @id
  sourceRowId     Int?     @unique @map("source_row_id")
  name            String
  nameI18n        Json?    @map("name_i18n")
  abbreviation    String?  @default("")
  aliases         String[] @default([])
  country         String
  countryI18n     Json?    @map("country_i18n")
  city            String
  cityI18n        Json?    @map("city_i18n")
  foundedYear     String   @map("founded_year")
  frequency       String
  frequencyI18n   Json?    @map("frequency_i18n")
  tagline         String
  introduction    String   @db.Text
  descriptionI18n Json?    @map("description_i18n")
  officialWebsite String?  @map("official_website")
  facebookUrl     String?  @map("facebook_url")
  instagramUrl    String?  @map("instagram_url")
  twitterUrl      String?  @map("twitter_url")
  youtubeUrl      String?  @map("youtube_url")
  tiktokUrl       String?  @map("tiktok_url")
  avatarUrl       String?  @map("avatar_url")
  backgroundUrl   String?  @map("background_url")
  links           Json?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  contributors WikiFestivalContributor[]
  events       Event[]

  @@index([name])
  @@index([country])
  @@map("wiki_festivals")
}

model WikiFestivalContributor {
  id         String   @id @default(uuid())
  festivalId String   @map("festival_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  festival WikiFestival @relation(fields: [festivalId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([festivalId, userId])
  @@index([festivalId])
  @@index([userId])
  @@map("wiki_festival_contributors")
}

model Checkin {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  eventId    String?  @map("event_id")
  djId       String?  @map("dj_id")
  type       String // "event" or "dj"
  note       String?
  photoUrl   String?  @map("photo_url")
  rating     Int? // 1-5
  attendedAt DateTime @default(now()) @map("attended_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dj    DJ?    @relation(fields: [djId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, attendedAt])
  @@index([eventId])
  @@index([djId])
  @@map("checkins")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String?  @map("following_id")
  djId        String?  @map("dj_id")
  type        String // "user" or "dj"
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User  @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following User? @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  dj        DJ?   @relation(fields: [djId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@unique([followerId, djId])
  @@index([followerId])
  @@index([followingId])
  @@index([djId])
  @@map("follows")
}

model DJSet {
  id            String    @id @default(uuid())
  djId          String    @map("dj_id")
  coDjIds       String[]  @default([]) @map("co_dj_ids")
  customDjNames String[]  @default([]) @map("custom_dj_names")
  uploadedById  String?   @map("uploaded_by_id")
  title         String
  slug          String    @unique
  description   String?
  thumbnailUrl  String?   @map("thumbnail_url")
  videoUrl      String    @map("video_url")
  platform      String // "youtube" or "bilibili"
  videoId       String    @map("video_id") // Platform-specific video ID
  duration      Int? // Duration in seconds
  recordedAt    DateTime? @map("recorded_at")
  venue         String?
  eventName     String?   @map("event_name")
  viewCount     Int       @default(0) @map("view_count")
  likeCount     Int       @default(0) @map("like_count")
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  dj         DJ          @relation(fields: [djId], references: [id], onDelete: Cascade)
  uploader   User?       @relation("UserUploadedSets", fields: [uploadedById], references: [id], onDelete: SetNull)
  tracks     Track[]
  tracklists Tracklist[]
  comments   Comment[]
  posts      Post[]

  @@index([djId])
  @@index([uploadedById])
  @@map("dj_sets")
}

model Tracklist {
  id           String   @id @default(uuid())
  setId        String   @map("set_id")
  uploadedById String   @map("uploaded_by_id")
  title        String? // Optional title for this tracklist version
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  set      DJSet            @relation(fields: [setId], references: [id], onDelete: Cascade)
  uploader User             @relation("UserUploadedTracklists", fields: [uploadedById], references: [id], onDelete: Cascade)
  tracks   TracklistTrack[]

  @@index([setId])
  @@index([uploadedById])
  @@map("tracklists")
}

model Track {
  id          String  @id @default(uuid())
  setId       String  @map("set_id")
  position    Int // Track order in the set
  startTime   Int     @map("start_time") // Start time in seconds
  endTime     Int?    @map("end_time") // End time in seconds
  title       String
  artist      String
  status      String  @default("released") // "released", "id", "remix", "edit"
  label       String?
  releaseYear Int?    @map("release_year")

  // Streaming links
  spotifyUrl      String? @map("spotify_url")
  spotifyId       String? @map("spotify_id")
  spotifyUri      String? @map("spotify_uri")
  appleMusicUrl   String? @map("apple_music_url")
  youtubeMusicUrl String? @map("youtube_music_url")
  soundcloudUrl   String? @map("soundcloud_url")
  beatportUrl     String? @map("beatport_url")
  neteaseUrl      String? @map("netease_url")
  neteaseId       String? @map("netease_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  set DJSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId])
  @@index([status])
  @@map("tracks")
}

model TracklistTrack {
  id          String  @id @default(uuid())
  tracklistId String  @map("tracklist_id")
  position    Int // Track order in the tracklist
  startTime   Int     @map("start_time") // Start time in seconds
  endTime     Int?    @map("end_time") // End time in seconds
  title       String
  artist      String
  status      String  @default("released") // "released", "id", "remix", "edit"
  label       String?
  releaseYear Int?    @map("release_year")

  // Streaming links
  spotifyUrl      String? @map("spotify_url")
  spotifyId       String? @map("spotify_id")
  spotifyUri      String? @map("spotify_uri")
  appleMusicUrl   String? @map("apple_music_url")
  youtubeMusicUrl String? @map("youtube_music_url")
  soundcloudUrl   String? @map("soundcloud_url")
  beatportUrl     String? @map("beatport_url")
  neteaseUrl      String? @map("netease_url")
  neteaseId       String? @map("netease_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tracklist Tracklist @relation(fields: [tracklistId], references: [id], onDelete: Cascade)

  @@index([tracklistId])
  @@index([status])
  @@map("tracklist_tracks")
}

model Comment {
  id        String   @id @default(uuid())
  setId     String   @map("set_id")
  userId    String   @map("user_id")
  parentId  String?  @map("parent_id") // For nested replies
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  set     DJSet     @relation(fields: [setId], references: [id], onDelete: Cascade)
  user    User      @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([setId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

model RatingEvent {
  id          String   @id @default(uuid())
  createdById String   @map("created_by_id")
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User         @relation("RatingEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  units     RatingUnit[]

  @@index([createdById])
  @@index([createdAt])
  @@map("rating_events")
}

model RatingUnit {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  createdById String   @map("created_by_id")
  name        String
  description String?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event     RatingEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User            @relation("RatingUnitCreator", fields: [createdById], references: [id], onDelete: Cascade)
  comments  RatingComment[]

  @@index([eventId])
  @@index([createdById])
  @@index([createdAt])
  @@map("rating_units")
}

model RatingComment {
  id        String   @id @default(uuid())
  unitId    String   @map("unit_id")
  userId    String   @map("user_id")
  score     Int
  content   String
