  updatedAt       DateTime @updatedAt @map("updated_at")

  event          Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User                   @relation("UserEventLiveComments", fields: [userId], references: [id], onDelete: Cascade)
  parentComment  EventLiveComment?      @relation("EventLiveCommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  childComments  EventLiveComment[]     @relation("EventLiveCommentReplies")
  rootComment    EventLiveComment?      @relation("EventLiveCommentThreads", fields: [rootCommentId], references: [id], onDelete: SetNull)
  threadComments EventLiveComment[]     @relation("EventLiveCommentThreads")
