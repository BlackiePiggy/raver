// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  username              String    @unique
  email                 String    @unique
  phoneNumber           String?   @unique @map("phone_number")
  passwordHash          String    @map("password_hash")
  displayName           String?   @map("display_name")
  displayNameNormalized String?   @unique @map("display_name_normalized")
  displayNameStatus     String    @default("pending") @map("display_name_status")
  displayNameReviewNote String?   @map("display_name_review_note")
  avatarUrl             String?   @map("avatar_url")
  avatarStatus          String    @default("none") @map("avatar_status")
  avatarReviewNote      String?   @map("avatar_review_note")
  bio                   String?
  location              String?
  favoriteDjIds         String[]  @default([]) @map("favorite_dj_ids")
  favoriteGenres        String[]  @default([]) @map("favorite_genres")
  isFollowersListPublic Boolean   @default(true) @map("is_followers_list_public")
  isFollowingListPublic Boolean   @default(true) @map("is_following_list_public")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastLoginAt           DateTime? @map("last_login_at")
  isVerified            Boolean   @default(false) @map("is_verified")
  isActive              Boolean   @default(true) @map("is_active")
  role                  String    @default("user")
  profileShareCode      String?   @unique @map("profile_share_code")
  profileShareQrCodeUrl String?   @map("profile_share_qr_code_url")
  regionCode            String    @default("JP") @map("region_code")
  birthYear             Int?      @map("birth_year")
  ageBand               String    @default("unknown") @map("age_band")
  guardianContactEmail  String?   @map("guardian_contact_email")
  ageDeclaredAt         DateTime? @map("age_declared_at")

  checkins            Checkin[]
  eventFavorites      EventFavorite[]
  follows             Follow[]        @relation("UserFollows")
  followers           Follow[]        @relation("UserFollowers")
  uploadedSets        DJSet[]         @relation("UserUploadedSets")
  djContributions     DJContributor[]
  publishedEvents     Event[]         @relation("UserPublishedEvents")
  uploadedTracklists  Tracklist[]     @relation("UserUploadedTracklists")
  comments            Comment[]       @relation("UserComments")
  createdRatingEvents RatingEvent[]   @relation("RatingEventCreator")
  createdRatingUnits  RatingUnit[]    @relation("RatingUnitCreator")
  ratingComments      RatingComment[] @relation("RatingCommentAuthor")

  // Community & Squad
  posts                            Post[]                            @relation("UserPosts")
  eventLiveComments                EventLiveComment[]                @relation("UserEventLiveComments")
  eventLiveCommentLikes            EventLiveCommentLike[]
  eventLiveCommentReplyTargets     EventLiveComment[]                @relation("EventLiveCommentReplyToUser")
  createdSquadOfflineActivities    SquadOfflineActivity[]            @relation("SquadOfflineActivityCreator")
  squadOfflineActivityJoins        SquadOfflineActivityParticipant[]
  squadOfflineActivityLocations    SquadOfflineActivityLocation[]
  squadOfflineActivityStatusEvents SquadOfflineActivityStatusEvent[]
  postLikes                        PostLike[]
  postReposts                      PostRepost[]
  postSaves                        PostSave[]
  postShares                       PostShare[]
  postHides                        PostHide[]
  feedEvents                       FeedEvent[]
  postComments                     PostComment[]
  postCommentReplyTargets          PostComment[]                     @relation("PostCommentReplyToUser")
  ledSquads                        Squad[]                           @relation("SquadLeader")
  squadMemberships                 SquadMember[]
  sentInvites                      SquadInvite[]                     @relation("SentInvites")
  receivedInvites                  SquadInvite[]                     @relation("ReceivedInvites")
  squadMessages                    SquadMessage[]
  directConversationsA             DirectConversation[]              @relation("DirectConversationUserA")
  directConversationsB             DirectConversation[]              @relation("DirectConversationUserB")
  directConversationReads          DirectConversationRead[]
  directMessages                   DirectMessage[]
  notificationReads                NotificationRead[]
  notificationSubscriptions        NotificationSubscription[]
  notificationInboxItems           NotificationInboxItem[]
  devicePushTokens                 DevicePushToken[]
  notificationDeliveries           NotificationDelivery[]
  contentSubmissions               ContentSubmission[]               @relation("UserContentSubmissions")
  djEnrichmentJobsRequested        DJEnrichmentJob[]                 @relation("UserDJEnrichmentJobsRequested")
  djEnrichmentResultsReviewed      DJEnrichmentResult[]              @relation("UserDJEnrichmentResultsReviewed")
  createdActivities                SquadActivity[]
  createdAlbums                    SquadAlbum[]
  uploadedPhotos                   SquadAlbumPhoto[]
  wikiFestivalContributions        WikiFestivalContributor[]
  authRefreshTokens                AuthRefreshToken[]
  createdShareLinks                ShareLink[]                       @relation("ShareLinkCreator")
  shareLinkEvents                  ShareLinkEvent[]
  sentInviteReferrals              InviteReferral[]                  @relation("InviteReferralInviter")
  receivedInviteReferrals          InviteReferral[]                  @relation("InviteReferralInvitee")
  profileModerationJobs            UserProfileModerationJob[]
  virtualAssets                    UserVirtualAsset[]
  virtualAssetEquips               UserVirtualAssetEquip[]
  accountEnforcements              AccountEnforcement[]
  enforcementAppeals               EnforcementAppeal[]
  accountDeletionRequests          AccountDeletionRequest[]

  @@index([regionCode])
  @@index([ageBand])
  @@map("users")
}

model AccountDeletionRequest {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  status               String    @default("queued")
  requestedBy          String    @default("user") @map("requested_by")
  requestSource        String    @default("ios") @map("request_source")
  originalEmailHash    String?   @map("original_email_hash")
  originalPhoneHash    String?   @map("original_phone_hash")
  previousAvatarUrl    String?   @map("previous_avatar_url") @db.Text
  previousProfileQrUrl String?   @map("previous_profile_qr_url") @db.Text
  imUserId             String?   @map("im_user_id")
  imStatus             String    @default("pending") @map("im_status")
  imAttempts           Int       @default(0) @map("im_attempts")
  imNextRunAt          DateTime  @default(now()) @map("im_next_run_at")
  imLastError          String?   @map("im_last_error") @db.Text
  mediaStatus          String    @default("pending") @map("media_status")
  mediaAttempts        Int       @default(0) @map("media_attempts")
  mediaNextRunAt       DateTime  @default(now()) @map("media_next_run_at")
  mediaLastError       String?   @map("media_last_error") @db.Text
  mediaTargets         Json?     @map("media_targets")
  completedAt          DateTime? @map("completed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([imStatus, imNextRunAt])
  @@index([mediaStatus, mediaNextRunAt])
  @@map("account_deletion_requests")
}

model ContentReport {
  id             String    @id @default(uuid())
  reporterUserId String    @map("reporter_user_id")
  targetType     String    @map("target_type")
  targetId       String    @map("target_id")
  targetUserId   String?   @map("target_user_id")
  reason         String
  detail         String?   @db.Text
  attachments    Json?
  source         String    @default("in_app")
  status         String    @default("pending")
  metadata       Json?
  resolvedAt     DateTime? @map("resolved_at")
  resolvedBy     String?   @map("resolved_by")
  resolutionNote String?   @map("resolution_note") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@unique([reporterUserId, targetType, targetId])
  @@index([reporterUserId, createdAt])
  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([targetUserId, createdAt])
  @@map("content_reports")
}

model ModerationDecisionTemplate {
  id          String    @id @default(uuid())
  templateKey String    @map("template_key")
  locale      String
  title       String
  body        String    @db.Text
  status      String    @default("draft")
  version     Int       @default(1)
  publishedAt DateTime? @map("published_at")
  publishedBy String?   @map("published_by")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([templateKey, locale, version])
  @@index([templateKey, locale, status])
  @@index([status, updatedAt])
  @@map("moderation_decision_templates")
}

model UserBlock {
  id            String   @id @default(uuid())
  blockerUserId String   @map("blocker_user_id")
  blockedUserId String   @map("blocked_user_id")
  reason        String?
  note          String?  @db.Text
  source        String   @default("in_app")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([blockerUserId, blockedUserId])
  @@index([blockerUserId, createdAt])
  @@index([blockedUserId, createdAt])
  @@map("user_blocks")
}

model AccountEnforcement {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  status              String    @default("active")
  type                String
  scopes              String[]  @default([])
  reasonCode          String    @map("reason_code")
  userMessageI18n     Json?     @map("user_message_i18n")
  internalNote        String?   @map("internal_note") @db.Text
  evidence            Json?
  startsAt            DateTime  @default(now()) @map("starts_at")
  endsAt              DateTime? @map("ends_at")
  createdBy           String?   @map("created_by")
  createdFromReportId String?   @map("created_from_report_id")
  createdFromCaseId   String?   @map("created_from_case_id")
  revokedAt           DateTime? @map("revoked_at")
  revokedBy           String?   @map("revoked_by")
  revocationReason    String?   @map("revocation_reason") @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  appeals EnforcementAppeal[]

  @@index([userId, status, startsAt])
  @@index([type, status, startsAt])
  @@index([reasonCode, status, startsAt])
  @@index([createdBy, createdAt])
  @@index([createdFromReportId])
  @@map("account_enforcements")
}

model EnforcementAppeal {
  id            String    @id @default(uuid())
  enforcementId String    @map("enforcement_id")
  userId        String    @map("user_id")
  status        String    @default("submitted")
  appealReason  String    @map("appeal_reason") @db.Text
  attachments   Json?
  contactEmail  String?   @map("contact_email")
  reviewerId    String?   @map("reviewer_id")
  decision      String?
  decisionNote  String?   @map("decision_note") @db.Text
  reviewedAt    DateTime? @map("reviewed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  enforcement AccountEnforcement @relation(fields: [enforcementId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enforcementId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([reviewerId, reviewedAt])
  @@map("enforcement_appeals")
}

model UserProfileModerationJob {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  targetType      String    @map("target_type")
  targetValue     String    @map("target_value") @db.Text
  normalizedValue String?   @map("normalized_value")
  status          String    @default("pending")
  reason          String?
  provider        String    @default("manual_review")
  decisionDetail  Json?     @map("decision_detail")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, targetType, createdAt])
  @@index([status, createdAt])
  @@map("user_profile_moderation_jobs")
}

model ContentSubmission {
  id              String    @id @default(uuid())
  submitterId     String    @map("submitter_id")
  entityType      String    @map("entity_type")
  status          String    @default("pending")
  title           String
  payload         Json
  reviewReason    String?   @map("review_reason") @db.Text
  reviewNotes     Json?     @map("review_notes")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdEntityId String?   @map("created_entity_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  submitter User                       @relation("UserContentSubmissions", fields: [submitterId], references: [id], onDelete: Cascade)
  versions  ContentSubmissionVersion[]

  @@index([submitterId, createdAt])
  @@index([entityType, status, createdAt])
  @@index([status, createdAt])
  @@map("content_submissions")
}

model ContentSubmissionVersion {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  version      Int
  title        String
  payload      Json
  submittedAt  DateTime @default(now()) @map("submitted_at")
  submittedBy  String?  @map("submitted_by")
  changeNote   String?  @map("change_note") @db.Text

  submission ContentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, version])
  @@index([submissionId, submittedAt])
  @@map("content_submission_versions")
}

model DJEnrichmentJob {
  id            String    @id @default(uuid())
  requestedById String    @map("requested_by_id")
  status        String    @default("pending")
  applyMode     String    @default("review_required") @map("apply_mode")
  totalCount    Int       @default(0) @map("total_count")
  queuedCount   Int       @default(0) @map("queued_count")
  runningCount  Int       @default(0) @map("running_count")
  successCount  Int       @default(0) @map("success_count")
  failedCount   Int       @default(0) @map("failed_count")
  reviewedCount Int       @default(0) @map("reviewed_count")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  lastError     String?   @map("last_error") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  requestedBy User                 @relation("UserDJEnrichmentJobsRequested", fields: [requestedById], references: [id], onDelete: Cascade)
  results     DJEnrichmentResult[]

  @@index([requestedById, createdAt])
  @@index([status, createdAt])
  @@map("dj_enrichment_jobs")
}

model DJEnrichmentResult {
  id                      String    @id @default(uuid())
  jobId                   String    @map("job_id")
  djId                    String?   @map("dj_id")
  inputName               String    @map("input_name")
  status                  String    @default("queued")
  applyStatus             String    @default("pending_review") @map("apply_status")
  inputPayload            Json      @map("input_payload")
  normalizedResult        Json?     @map("normalized_result")
  cozeRawResponse         Json?     @map("coze_raw_response")
  matchConfidence         Float?    @map("match_confidence")
  isMatchConfident        Boolean   @default(false) @map("is_match_confident")
  electronicConfidence    Float?    @map("electronic_confidence")
  isElectronicDjConfident Boolean   @default(false) @map("is_electronic_dj_confident")
  genreConfidence         Float?    @map("genre_confidence")
  shouldApplyGenres       Boolean   @default(false) @map("should_apply_genres")
  reviewReason            String?   @map("review_reason") @db.Text
  reviewNotes             Json?     @map("review_notes")
  reviewedAt              DateTime? @map("reviewed_at")
  reviewedById            String?   @map("reviewed_by_id")
  appliedAt               DateTime? @map("applied_at")
  applySummary            Json?     @map("apply_summary")
  errorMessage            String?   @map("error_message") @db.Text
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  job        DJEnrichmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  dj         DJ?             @relation(fields: [djId], references: [id], onDelete: SetNull)
  reviewedBy User?           @relation("UserDJEnrichmentResultsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([jobId, createdAt])
  @@index([djId, createdAt])
  @@index([status, applyStatus, createdAt])
  @@index([reviewedById, reviewedAt])
  @@map("dj_enrichment_results")
}

model Event {
  id                String   @id @default(uuid())
  organizerId       String?  @map("organizer_id")
  wikiFestivalId    String?  @map("wiki_festival_id")
  archiveFestivalId String?  @unique @map("archive_festival_id")
  name              String
  nameI18n          Json?    @map("name_i18n")
  slug              String   @unique
  description       String?
  descriptionI18n   Json?    @map("description_i18n")
  locationI18n      Json?    @map("location_i18n")
  countryI18n       Json?    @map("country_i18n")
  cityI18n          Json?    @map("city_i18n")
  coverImageUrl     String?  @map("cover_image_url")
  lineupImageUrl    String?  @map("lineup_image_url")
  imageAssets       Json?    @map("image_assets")
  referenceLinks    String[] @default([]) @map("reference_links")
  socialLinks       Json?    @map("social_links")
  sourceProvider    String?  @map("source_provider")
  sourceEventUrl    String?  @map("source_event_url")
  eventType         String?  @map("event_type")
  organizerName     String?  @map("organizer_name")
  venueName         String?  @map("venue_name")
  venueAddress      String?  @map("venue_address")
  city              String?
  country           String?
  manualLocation    Json?    @map("manual_location")
  locationPoint     Json?    @map("location_point")
  latitude          Decimal? @db.Decimal(10, 8)
  longitude         Decimal? @db.Decimal(11, 8)
  startDate         DateTime @map("start_date")
  endDate           DateTime @map("end_date")
  timeZone          String   @default("Asia/Shanghai") @map("time_zone")
  startTime         String   @default("00:00:00") @map("start_time")
  endTime           String   @default("23:59:59") @map("end_time")
  dayRolloverHour   Int      @default(6) @map("day_rollover_hour")
  stageOrder        Json?    @map("stage_order")
  ticketUrl         String?  @map("ticket_url")
  ticketPriceMin    Decimal? @map("ticket_price_min") @db.Decimal(10, 2)
  ticketPriceMax    Decimal? @map("ticket_price_max") @db.Decimal(10, 2)
  ticketCurrency    String?  @map("ticket_currency")
  ticketNotes       String?  @map("ticket_notes")
  officialWebsite   String?  @map("official_website")
  status            String   @default("upcoming")
  isVerified        Boolean  @default(false) @map("is_verified")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organizer              User?                  @relation("UserPublishedEvents", fields: [organizerId], references: [id], onDelete: SetNull)
  wikiFestival           WikiFestival?          @relation(fields: [wikiFestivalId], references: [id], onDelete: SetNull)
  checkins               Checkin[]
  favorites              EventFavorite[]
  lineupSlots            EventLineupSlot[]
  lineupArtists          EventLineupArtist[]
  timetableSlots         EventTimetableSlot[]
  ticketTiers            EventTicketTier[]
  posts                  Post[]
  liveComments           EventLiveComment[]
  squadActivities        SquadActivity[]
  squadOfflineActivities SquadOfflineActivity[]

  @@index([organizerId])
  @@index([wikiFestivalId])
  @@map("events")
}

model EventFavorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId, createdAt])
  @@index([eventId, createdAt])
  @@map("event_favorites")
}

model EventTicketTier {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  name      String
  price     Decimal  @db.Decimal(10, 2)
  currency  String?  @map("currency")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([sortOrder])
  @@map("event_ticket_tiers")
}

model EventLineupSlot {
  id               String   @id @default(uuid())
  eventId          String   @map("event_id")
  djId             String?  @map("dj_id")
  djIds            String[] @default([]) @map("dj_ids")
  festivalDayIndex Int?     @map("festival_day_index")
  djName           String   @map("dj_name")
  stageName        String?  @map("stage_name")
  sortOrder        Int      @default(0) @map("sort_order")
  startTime        DateTime @map("start_time")
  endTime          DateTime @map("end_time")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dj    DJ?   @relation(fields: [djId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([djId])
  @@index([startTime])
  @@map("event_lineup_slots")
}

model EventLineupArtist {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  djId      String?  @map("dj_id")
  djIds     String[] @default([]) @map("dj_ids")
  djName    String   @map("dj_name")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event          Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dj             DJ?                  @relation(fields: [djId], references: [id], onDelete: SetNull)
  timetableSlots EventTimetableSlot[]

  @@index([eventId])
  @@index([djId])
  @@map("event_lineup_artists")
}

model EventTimetableSlot {
  id               String   @id @default(uuid())
  eventId          String   @map("event_id")
  lineupArtistId   String?  @map("lineup_artist_id")
  djId             String?  @map("dj_id")
  djIds            String[] @default([]) @map("dj_ids")
  djNameSnapshot   String   @map("dj_name_snapshot")
  stageName        String?  @map("stage_name")
  festivalDayIndex Int?     @map("festival_day_index")
  startTime        DateTime @map("start_time")
  endTime          DateTime @map("end_time")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  lineupArtist EventLineupArtist? @relation(fields: [lineupArtistId], references: [id], onDelete: SetNull)
  dj           DJ?                @relation(fields: [djId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([lineupArtistId])
  @@index([djId])
  @@index([startTime])
  @@map("event_timetable_slots")
}

model DJ {
  id                  String   @id @default(uuid())
  name                String
  nameI18n            Json?    @map("name_i18n")
  aliases             String[] @default([])
  genres              String[] @default([])
  slug                String   @unique
  bio                 String?
  bioI18n             Json?    @map("bio_i18n")
  avatarUrl           String?  @map("avatar_url")
  avatarSourceUrl     String?  @map("avatar_source_url")
  bannerUrl           String?  @map("banner_url")
  country             String?
  countryI18n         Json?    @map("country_i18n")
  spotifyUrl          String?  @map("spotify_url")
  spotifyId           String?  @map("spotify_id")
  spotifyFollowers    Int?     @map("spotify_followers")
  appleMusicId        String?  @map("apple_music_id")
  soundcloudUrl       String?  @map("soundcloud_url")
  soundcloudId        String?  @map("soundcloud_id")
  neteaseUrl          String?  @map("netease_url")
  qqMusicUrl          String?  @map("qq_music_url")
  website             String?  @map("website")
  trackCount          Int?     @map("track_count")
  playlistCount       Int?     @map("playlist_count")
  soundCloudFollowers Int?     @map("soundcloud_followers")
  soundCloudFavorites Int?     @map("soundcloud_favorites")
