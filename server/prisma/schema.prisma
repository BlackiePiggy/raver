  updatedAt      DateTime @updatedAt @map("updated_at")

  batch        PreRegistrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  registration PreRegistration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([batchId, registrationId])
  @@index([batchId, decision])
  @@index([registrationId, decision])
  @@map("pre_registration_decisions")
}

model PreRegistrationNotification {
  id                String   @id @default(uuid())
  registrationId    String   @map("registration_id")
  batchId           String?  @map("batch_id")
  channel           String
  templateKey       String   @map("template_key")
  sendStatus        String   @default("PENDING") @map("send_status")
  providerMessageId String?  @map("provider_message_id")
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  registration PreRegistration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  batch        PreRegistrationBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([batchId, channel, createdAt])
  @@index([registrationId, channel, createdAt])
  @@index([sendStatus, createdAt])
  @@map("pre_registration_notifications")
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("admin_audit_logs")
}

model AuthRefreshToken {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  tokenHash        String    @unique @map("token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  lastUsedAt       DateTime? @map("last_used_at")
  revokedAt        DateTime? @map("revoked_at")
  replacedByTokenId String?  @map("replaced_by_token_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy    AuthRefreshToken? @relation("AuthRefreshTokenRotation", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  previousTokens AuthRefreshToken[] @relation("AuthRefreshTokenRotation")

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
  @@map("auth_refresh_tokens")
}

model AuthSmsCode {
  id          String    @id @default(uuid())
  phoneNumber String    @map("phone_number")
  scene       String    @default("login")
  codeHash    String    @map("code_hash")
  sendIp      String?   @map("send_ip")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([phoneNumber, scene, createdAt])
  @@index([phoneNumber, scene, expiresAt])
  @@index([sendIp, createdAt])
  @@map("auth_sms_codes")
}

model AuthPhoneAuthState {
  phoneNumber    String    @id @map("phone_number")
  failedAttempts Int       @default(0) @map("failed_attempts")
  blockedUntil   DateTime? @map("blocked_until")
  lastFailedAt   DateTime? @map("last_failed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("auth_phone_auth_states")
}
