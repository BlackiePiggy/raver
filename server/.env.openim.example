# OpenIM integration
#
# Copy these keys into server/.env for local OpenIM verification.
# Do not commit real secrets.

OPENIM_ENABLED=false
OPENIM_API_BASE_URL=http://127.0.0.1:10002
OPENIM_WS_URL=ws://127.0.0.1:10001
# Optional: client bootstrap override (useful for real-device testing).
# Keep OPENIM_API_BASE_URL / OPENIM_WS_URL for server->OpenIM calls,
# and set these to LAN/domain reachable by iPhone.
OPENIM_CLIENT_API_BASE_URL=
OPENIM_CLIENT_WS_URL=
OPENIM_ADMIN_USER_ID=imAdmin
OPENIM_ADMIN_SECRET=
OPENIM_PLATFORM_ID=1
OPENIM_SYSTEM_USER_ID=raver_system
OPENIM_REQUEST_TIMEOUT_MS=10000
# Temporary fallback for OpenIM v3.8.3 kick_group bug ("maxSeq is invalid").
OPENIM_TOLERATE_KICK_MAXSEQ_ISSUE=false
OPENIM_SYNC_WORKER_ENABLED=true
OPENIM_SYNC_WORKER_INTERVAL_MS=5000
OPENIM_SYNC_WORKER_BATCH_SIZE=20
OPENIM_SYNC_LOCK_TIMEOUT_MS=60000
OPENIM_SYNC_DEFAULT_MAX_ATTEMPTS=5
OPENIM_WEBHOOK_SECRET=
OPENIM_WEBHOOK_REQUIRE_SIGNATURE=true
OPENIM_WEBHOOK_TOLERANCE_SECONDS=300
OPENIM_WEBHOOK_BLOCK_SENSITIVE_WORDS=false
OPENIM_WEBHOOK_BLOCK_IMAGE_HITS=false
# Example: OPENIM_SENSITIVE_WORDS=drug,scam,spam
OPENIM_SENSITIVE_WORDS=
# Example: OPENIM_SENSITIVE_PATTERNS=/\\b(?:wx|v信)\\b/iu
OPENIM_SENSITIVE_PATTERNS=
OPENIM_IMAGE_MODERATION_ENABLED=false
# Example: OPENIM_IMAGE_MODERATION_BLOCK_KEYWORDS=nsfw,illegal
OPENIM_IMAGE_MODERATION_BLOCK_KEYWORDS=
# Example: OPENIM_IMAGE_MODERATION_ALLOWED_HOSTS=cdn.raverapp.com,oss-cn-shanghai.aliyuncs.com
OPENIM_IMAGE_MODERATION_ALLOWED_HOSTS=
OPENIM_IMAGE_MODERATION_MAX_URLS=10

# Override these if your OpenIM version uses different REST paths.
OPENIM_PATH_GET_ADMIN_TOKEN=/auth/get_admin_token
OPENIM_PATH_GET_USER_TOKEN=/auth/get_user_token
OPENIM_PATH_USER_REGISTER=/user/user_register
OPENIM_PATH_UPDATE_USER_INFO=/user/update_user_info_ex
OPENIM_PATH_CREATE_GROUP=/group/create_group
OPENIM_PATH_INVITE_USER_TO_GROUP=/group/invite_user_to_group
OPENIM_PATH_KICK_GROUP=/group/kick_group
OPENIM_PATH_SET_GROUP_INFO=/group/set_group_info_ex
OPENIM_PATH_SET_GROUP_MEMBER_INFO=/group/set_group_member_info
OPENIM_PATH_TRANSFER_GROUP=/group/transfer_group
OPENIM_PATH_SEND_MESSAGE=/msg/send_msg
OPENIM_PATH_REVOKE_MESSAGE=/msg/revoke_msg
OPENIM_PATH_DELETE_MESSAGE=/msg/delete_msg

# Smoke script options.
OPENIM_SMOKE_USER_ID=
OPENIM_SMOKE_CREATE_GROUP=false
OPENIM_SMOKE_GROUP_OWNER_ID=
OPENIM_SMOKE_GROUP_MEMBER_IDS=
OPENIM_SMOKE_GROUP_ID=
OPENIM_SMOKE_SYNC_GROUP_INFO=false
OPENIM_SMOKE_PROMOTE_ADMIN_USER_ID=
OPENIM_SMOKE_TRANSFER_GROUP_TO_USER_ID=
OPENIM_SMOKE_KICK_GROUP_MEMBER_IDS=
# When true, smoke treats the known kick_group maxSeq issue as tolerated warning.
OPENIM_SMOKE_ALLOW_KICK_KNOWN_ISSUE=false

# BFF squad manage smoke (create -> promote admin -> transfer leader -> remove member -> old leader leave)
OPENIM_BFF_BASE_URL=http://localhost:3901
OPENIM_BFF_SMOKE_LEADER_USERNAME=
OPENIM_BFF_SMOKE_LEADER_PASSWORD=
OPENIM_BFF_SMOKE_MEMBER_A_USERNAME=
OPENIM_BFF_SMOKE_MEMBER_A_PASSWORD=
OPENIM_BFF_SMOKE_MEMBER_B_USERNAME=
OPENIM_BFF_SMOKE_MEMBER_B_PASSWORD=
OPENIM_BFF_SMOKE_SQUAD_NAME=

# OpenIM realtime probe sender (direct or group, server-side injection)
# single | group
OPENIM_PROBE_SESSION_TYPE=single
OPENIM_PROBE_SENDER_IDENTIFIER=
OPENIM_PROBE_RECEIVER_IDENTIFIER=
OPENIM_PROBE_GROUP_ID=
OPENIM_PROBE_MESSAGE_COUNT=3
OPENIM_PROBE_INTERVAL_MS=800
OPENIM_PROBE_MESSAGE_PREFIX=[openim-probe]

# Migration script options.
OPENIM_MIGRATION_DRYRUN_MODE=all
OPENIM_MIGRATION_DRYRUN_PERSIST=false
OPENIM_MIGRATION_SOURCE_TYPE=all
OPENIM_MIGRATION_EXECUTE_SEND=false
OPENIM_MIGRATION_EXECUTE_BATCH_SIZE=50
OPENIM_MIGRATION_EXECUTE_MAX_MESSAGES=500
OPENIM_MIGRATION_FAIL_FAST=false
OPENIM_MIGRATION_INCLUDE_FAILED=false
OPENIM_MIGRATION_REPORT_PATH=

# Squad OpenIM group reconcile options.
OPENIM_SQUAD_RECONCILE_EXECUTE=false
OPENIM_SQUAD_RECONCILE_ONLY_WITH_MESSAGES=true
OPENIM_SQUAD_RECONCILE_LIMIT=200
OPENIM_SQUAD_RECONCILE_REPORT_PATH=

# Local OpenIM load test options.
OPENIM_LOAD_TEST_USERS=20
OPENIM_LOAD_TEST_DIRECT_MESSAGES=100
OPENIM_LOAD_TEST_GROUP_MESSAGES=100
OPENIM_LOAD_TEST_GROUP_SIZE=10
OPENIM_LOAD_TEST_CONCURRENCY=10
OPENIM_LOAD_TEST_RUN_ID=
OPENIM_LOAD_TEST_REPORT_PATH=

# Notification Center APNs provider (server side)
NOTIFICATION_APNS_ENABLED=false
NOTIFICATION_APNS_KEY_ID=
NOTIFICATION_APNS_TEAM_ID=
NOTIFICATION_APNS_BUNDLE_ID=
# One of these private key options should be set.
NOTIFICATION_APNS_PRIVATE_KEY_PATH=
NOTIFICATION_APNS_PRIVATE_KEY=
NOTIFICATION_APNS_PRIVATE_KEY_BASE64=
# true for development/sandbox; false for production APNs endpoint.
NOTIFICATION_APNS_USE_SANDBOX=true

# Notification Center outbox worker (Phase 2 skeleton)
# When enabled, publish will enqueue non-in_app channels as queued deliveries.
NOTIFICATION_OUTBOX_ASYNC_ENABLED=false
# Worker loop to dispatch queued deliveries.
NOTIFICATION_OUTBOX_WORKER_ENABLED=false
NOTIFICATION_OUTBOX_WORKER_INTERVAL_MS=5000
NOTIFICATION_OUTBOX_WORKER_EVENT_LIMIT=20

# Outbox gray verification script options (notification:outbox:gray-verify)
NOTIFICATION_GRAY_BASE_URL=http://localhost:3901
NOTIFICATION_GRAY_ADMIN_USERNAME=uploadtester
NOTIFICATION_GRAY_ADMIN_PASSWORD=123456
# Optional: override target user; defaults to login user id.
NOTIFICATION_GRAY_TARGET_USER_ID=
NOTIFICATION_GRAY_CHANNELS=in_app,apns
NOTIFICATION_GRAY_ROUNDS=3
NOTIFICATION_GRAY_TIMEOUT_MS=60000
NOTIFICATION_GRAY_POLL_INTERVAL_MS=2000
NOTIFICATION_GRAY_REQUIRE_QUEUED_DETAIL=true
NOTIFICATION_GRAY_MAX_QUEUED_DRIFT=0
NOTIFICATION_GRAY_CATEGORY=major_news

# Notification Center event countdown scheduler (Phase N3)
NOTIFICATION_EVENT_COUNTDOWN_ENABLED=false
NOTIFICATION_EVENT_COUNTDOWN_INTERVAL_MS=300000
NOTIFICATION_EVENT_COUNTDOWN_MAX_DAYS=60

# Notification Center event daily digest scheduler (Phase N3)
NOTIFICATION_EVENT_DAILY_DIGEST_ENABLED=false
NOTIFICATION_EVENT_DAILY_DIGEST_INTERVAL_MS=600000
NOTIFICATION_EVENT_DAILY_DIGEST_MAX_DAYS_BEFORE_START=60
NOTIFICATION_EVENT_DAILY_DIGEST_MAX_DAYS_AFTER_END=1
NOTIFICATION_EVENT_DAILY_DIGEST_LOOKBACK_HOURS=24

# Notification Center route DJ reminder scheduler (Phase N3)
NOTIFICATION_ROUTE_DJ_REMINDER_ENABLED=false
NOTIFICATION_ROUTE_DJ_REMINDER_INTERVAL_MS=60000
NOTIFICATION_ROUTE_DJ_REMINDER_LOOKAHEAD_MINUTES=180
NOTIFICATION_ROUTE_DJ_REMINDER_TRIGGER_WINDOW_MINUTES=3

# Notification Center followed DJ updates scheduler (Phase N3)
NOTIFICATION_FOLLOWED_DJ_UPDATE_ENABLED=false
NOTIFICATION_FOLLOWED_DJ_UPDATE_INTERVAL_MS=600000
NOTIFICATION_FOLLOWED_DJ_UPDATE_LOOKBACK_HOURS=24

# Notification Center followed Brand updates scheduler (Phase N3)
NOTIFICATION_FOLLOWED_BRAND_UPDATE_ENABLED=false
NOTIFICATION_FOLLOWED_BRAND_UPDATE_INTERVAL_MS=600000
NOTIFICATION_FOLLOWED_BRAND_UPDATE_LOOKBACK_HOURS=24
